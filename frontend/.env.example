# n8n webhook URLs — server-side only. Read by app/actions.ts and
# app/api/status/route.ts. Never reference these from a client component.
N8N_INTAKE_WEBHOOK_URL=
N8N_STATUS_WEBHOOK_URL=

# Vercel Blob — auto-populated when a Blob store is connected to this
# Vercel project (Storage tab). For local dev: connect the store, then run
# `vercel env pull frontend/.env.local` from the repo root.
BLOB_READ_WRITE_TOKEN=
